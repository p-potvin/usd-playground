#usda 1.0
(
    upAxis = "Y"
)

def "Environment"
{
    def Plane "Ground"
    {
        double length = 100
        double width = 100
    }

    def DistantLight "Sun"
    {
        float inputs:intensity = 1000
    }
}

over "DigitalTwin" (
    prepend references = @data/reconstruction/cloud.usda@
)
{
}
